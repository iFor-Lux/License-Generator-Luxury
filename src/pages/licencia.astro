---
import Layout from "../layouts/Layout.astro";
import Profile from "../components/Profile.astro";
import DiscordCard from "../components/DiscordCard.astro";
import GroupCard from "../components/GroupCard.astro";
import Terminal from "../components/Terminal.astro";
import Socials from "../components/Socials.astro";
import Location from "../components/Location.astro";
import AudioPlayer from "../components/AudioPlayer.astro";
import Noise from "../components/Noise.jsx";
---

<Layout>
	<main>
		<video autoplay loop muted playsinline class="bg-video">
			<source src="https://images.guns.lol/31c0364b9e0a58a873bbe97f0378895eefe318fa/J96mcv.mp4" type="video/mp4" />
		</video>
		<Noise
			client:load
			patternSize={250}
			patternScaleX={2}
			patternScaleY={2}
			patternRefreshInterval={2}
			patternAlpha={15}
		/>
		<!-- Cuadro Único Maestro -->
		<div class="premium-box master-container">
			<!-- Fila de Perfil -->
			<Profile />

			<!-- Fila de Tarjetas (Comunidad) -->
			<div class="cards-row">
				<DiscordCard />
				<GroupCard />
			</div>

			<!-- Terminal Aceternity Style (Licencias) -->
			<Terminal />

			<!-- Nueva Sección de Redes Sociales (Bajo la Terminal) -->
			<Socials />

			<!-- Nueva Sección de Ubicación / Maps -->
			<Location />

			<div class="glow"></div>
		</div>

		<!-- Luxury Master Audio Interface (v5 - User Reference) -->
		<AudioPlayer />
	</main>
</Layout>

<style is:global>
	/* Forzar transparencia para ver el video */
	html,
	body {
		background: transparent !important;
	}

	.bg-video {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: -1;
	}

	/* Ocultar el fondo anterior del Layout */
	.bg-gradient {
		display: none !important;
	}

	main {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		width: 100%;
		min-height: 100vh;
		padding: 2rem 1rem;
		gap: 0;
	}

	.master-container {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 2rem 1.5rem;
		width: 95%;
		max-width: 710px;
		background: rgba(10, 10, 10, 0.45);
		backdrop-filter: blur(50px);
		-webkit-backdrop-filter: blur(50px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 32px;
		gap: 1.5rem;
		box-shadow: 0 60px 120px -30px rgba(0, 0, 0, 0.9);
		animation: slideIn 1.2s cubic-bezier(0.16, 1, 0.3, 1);
		z-index: 10;
		overflow: visible !important;
	}

	/* Fila de Tarjetas */
	.cards-row {
		display: flex;
		flex-direction: row;
		flex-wrap: nowrap;
		justify-content: center;
		gap: 12px;
		width: 100%;
	}

	.glow {
		position: absolute;
		top: -100px;
		left: -100px;
		width: 400px;
		height: 400px;
		background: radial-gradient(
			circle,
			rgba(255, 204, 51, 0.08) 0%,
			transparent 75%
		);
		z-index: -1;
		pointer-events: none;
	}

	@keyframes slideIn {
		from {
			opacity: 0;
			transform: translateX(-40px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	/* Media Queries Generales */
	@media (min-width: 768px) {
		.master-container {
			padding: 2rem 2.5rem;
			gap: 2rem;
		}
	}

	@media (min-width: 1024px) {
		.master-container {
			padding: 2.5rem;
			gap: 2.5rem;
		}
	}

	@media (max-width: 650px) {
		.cards-row {
			flex-direction: column;
			align-items: center;
		}
	}

	@media (max-width: 480px) {
		main {
			padding: 1rem 0.5rem;
		}
		.master-container {
			padding: 1rem 0.75rem;
			gap: 1rem;
			border-radius: 24px;
		}
		.cards-row {
			gap: 1rem;
		}
	}
</style>