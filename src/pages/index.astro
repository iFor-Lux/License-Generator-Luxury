---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<main>
		<video autoplay loop muted playsinline class="bg-video">
			<source src="https://r2.guns.lol/5a145775-fe79-497f-8dea-33a4f4902df0.mp4" type="video/mp4" />
		</video>
		<!-- Cuadro Único Maestro -->
		<div class="premium-box master-container">
			<!-- Fila de Perfil -->
			<div class="profile-row">
				<div class="image-wrapper">
					<m3e-shape name="7-sided-cookie" class="cookie-shape">
						<img
							src="/profile.png"
							alt="Profile"
							class="profile-img"
						/>
					</m3e-shape>
				</div>
				<div class="content">
					<h1 class="title">
						<span id="typewriter"></span>
						<div class="badge-wrapper" data-tooltip="Verificado">
							<svg class="verified-badge" viewBox="1 1.5 22 21">
								<path
									fill="currentColor"
									d="m8.6 22.5l-1.9-3.2l-3.6-.8l.35-3.7L1 12l2.45-2.8l-.35-3.7l3.6-.8l1.9-3.2L12 2.95l3.4-1.45l1.9 3.2l3.6.8l-.35 3.7L23 12l-2.45 2.8l.35 3.7l-3.6.8l-1.9 3.2l-3.4-1.45l-3.4 1.45Z"
								></path>
								<path
									fill="white"
									d="M10.95 15.55L16.6 9.9l-1.4-1.45l-4.25 4.25l-2.15-2.1L7.4 12l3.55 3.55Z"
								></path>
							</svg>
						</div>
					</h1>
					<p class="description">
						Somos @Luxuryregedit, una empresa con más de 5 años de
						experiencia en el mercado siempre entregando el mejor
						producto al menor precio posible.
					</p>
				</div>
			</div>

			<!-- Fila de Tarjetas (Comunidad) -->
			<div class="cards-row">
				<!-- Tarjeta Discord -->
				<div class="card discord-card">
					<div class="card-left">
						<div class="pfp-container">
							<img
								id="discord-pfp"
								class="pfp-circle"
								src=""
								alt=""
								style="display: none;"
							/>
							<div
								id="discord-pfp-placeholder"
								class="pfp-circle"
							>
							</div>
							<div id="discord-status" class="status-dot"></div>
						</div>
						<div class="info">
							<div class="name-row">
								<span id="discord-username" class="username"
								></span>
							</div>
							<p id="discord-activity-name" class="subtitle"></p>
							<p id="discord-activity-details" class="details">
							</p>
						</div>
					</div>
					<div class="card-right">
						<div
							id="discord-tech-box"
							class="tech-box"
							data-tooltip="Activity Profile"
						>
							<svg
								id="discord-default-icon"
								viewBox="0 0 24 24"
								fill="none"
								class="react-icon"
							>
								<path
									d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
									stroke="#61dafb"
									stroke-width="2"></path>
								<path
									d="M12 8L12 16M8 12L16 12"
									stroke="#61dafb"
									stroke-width="2"
									stroke-linecap="round"></path>
							</svg>
							<img
								id="discord-activity-icon"
								src=""
								alt=""
								style="display: none; width: 100%; height: 100%; border-radius: 10px; object-fit: cover;"
							/>
						</div>
					</div>
				</div>

				<!-- Group Card -->
				<div class="card group-card">

					<div class="card-left">
						<div
							class="group-avatar-container"
							data-tooltip="Join our Community"
						>
							<img
								src="/luxury-pfp.png"
								alt="Group"
								class="group-avatar"
							/>
						</div>
						<div class="info">
							<span class="group-name">Luxury Clientes</span>
							<div class="subs-row">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									class="users-icon"
									><path
										d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
									></path><circle cx="9" cy="7" r="4"
									></circle><path
										d="M23 21v-2a4 4 0 0 0-3-3.87"
									></path><path d="M16 3.13a4 4 0 0 1 0 7.75"
									></path></svg
								>
								<span class="subs-count">7,321 Clientes</span>
							</div>
							<a href="#" class="join-pill">Comprar</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Terminal Aceternity Style (Licencias) -->
			<div class="terminal-container">
				<div class="terminal-window">
					<div class="terminal-ambient-glow"></div>
					<div class="terminal-nav">
						<div class="terminal-dots">
							<div class="dot d-red"></div>
							<div class="dot d-yellow"></div>
							<div class="dot d-green"></div>
						</div>
						<div class="terminal-title">luxury-terminal</div>
					</div>
					<div class="terminal-viewport">
						<div id="terminal-content" class="terminal-log">
							<div class="log-line">
								<span class="p-prompt">luxury:~$</span>
								<span>system --status</span>
							</div>
							<div class="log-line">
								<span class="p-success">✓ </span>
								<span
									>System operational. Ready for generation.</span
								>
							</div>
						</div>
					</div>
					<div class="terminal-footer">
						<div class="footer-spacer-l"></div>
						<button id="generate-btn" class="terminal-btn">
							<span class="btn-text">Generar Licencia</span>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2.5"
								class="btn-icon"
							>
								<path
									d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"
								></path>
							</svg>
						</button>
						<div class="footer-spacer-r"></div>
						<div
							id="license-output"
							class="terminal-output"
						>
							<code id="license-code"></code>
							<button id="copy-btn" class="copy-small" data-tooltip="Copiar">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.5"
									class="copy-icon-s"
								>
									<rect
										x="9"
										y="9"
										width="13"
										height="13"
										rx="2"
										ry="2"></rect>
									<path
										d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
									></path>
								</svg>
							</button>
						</div>
					</div>
				</div>
			</div>

			<!-- Nueva Sección de Redes Sociales (Bajo la Terminal) -->
			<div class="footer-socials">
				<a href="#" class="social-icon-btn" data-tooltip="YouTube">
					<svg viewBox="0 0 24 24" fill="currentColor"
						><path
							d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
						></path></svg
					>
				</a>
				<a href="#" class="social-icon-btn" data-tooltip="Telegram">
					<svg viewBox="0 0 24 24" fill="currentColor"
						><path
							d="M20.665 3.717l-17.73 6.837c-1.21.486-1.203 1.161-.222 1.462l4.552 1.42 1.589 4.86c.191.533.097.744.521.744.329 0 .474-.15.658-.334.25-.249.773-.758 1.513-1.47l4.136 3.055c.762.42 1.309.203 1.499-.706l2.715-12.812c.277-1.114-.424-1.618-1.531-1.116z"
						></path></svg
					>
				</a>
				<a href="#" class="social-icon-btn" data-tooltip="Instagram">
					<svg viewBox="0 0 24 24" fill="currentColor"
						><path
							d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.947.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.947-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.947 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
						></path></svg
					>
				</a>
				<a href="#" class="social-icon-btn" data-tooltip="Discord">
					<svg viewBox="0 0 24 24" fill="currentColor"
						><path
							d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037 19.736 19.736 0 0 0-4.885 1.515.069.069 0 0 0-.032.027C.533 9.048-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.372.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
						></path></svg
					>
				</a>
			</div>

			<!-- Nueva Sección de Ubicación / Maps -->
			<div class="location-footer">
				<div class="location-pill" data-tooltip="@iFor._ez">
					<div class="pill-item">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="pill-icon eye-icon">
							<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
							<circle cx="12" cy="12" r="3"></circle>
						</svg>
						<span class="pill-text">12,348</span>
					</div>
					<span class="pill-sep">|</span>
					<div class="pill-item">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="pill-icon map-icon">
							<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
							<circle cx="12" cy="10" r="3"></circle>
						</svg>
						<span class="pill-text">&lt;$</span>
					</div>
				</div>
			</div>

			<div class="glow"></div>
		</div>

		<!-- Luxury Master Audio Interface (v5 - User Reference) -->
		<div class="audio-master-container">
			<div class="audio-master-card">
				<!-- Top Section: Info & Controls -->
				<div class="master-top">
					<div class="master-info-group">
						<div class="master-avatar-circle">
							<img src="/music-cover.png" alt="Art" />
						</div>
						<div class="master-text">
							<span id="player-status" class="now-playing">STOPPED</span>
							<div class="master-title-wrapper">
								<span class="master-title">Swing Lynn ( Slowed to Perfection )</span>
							</div>
						</div>
					</div>

					<div class="master-controls-group">
						<div class="visualizer-dots">
							<span>.</span><span>.</span><span>.</span><span>.</span>
						</div>
						<div class="circle-controls">
							<button id="master-prev" class="circle-btn" title="Prev">
								<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
							</button>
							<button id="master-play-pause" class="circle-btn" title="Play/Pause">
								<svg id="m-play" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
								<svg id="m-pause" viewBox="0 0 24 24" fill="currentColor" style="display: none;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
							</button>
							<button id="master-next" class="circle-btn" title="Next">
								<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
							</button>
						</div>
					</div>
				</div>

				<!-- Bottom Section: Progress & Volume -->
				<div class="master-bottom">
					<div class="progress-section">
						<div class="m-progress-container">
							<div id="m-seek" class="m-progress-bar">
								<div id="m-fill" class="m-fill">
									<div class="m-thumb"></div>
								</div>
							</div>
							<div class="m-time-row">
								<span id="m-current" class="time-label">0:01</span>
								<span class="time-label">6:20</span>
							</div>
						</div>
					</div>
					
					<div class="volume-section">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="vol-icon"><path d="M11 5L6 9H2v6h4l5 4V5z"></path></svg>
						<div id="vol-control" class="vol-bar">
							<div id="vol-fill" class="vol-fill"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script>
	import "@m3e/web/shape";
	import Typewriter from "typewriter-effect/dist/core";

	// --- LOGICA DE TYPEWRITER ---
	const typewriterElement = document.getElementById("typewriter");
	if (typewriterElement) {
		new Typewriter(typewriterElement, {
			strings: [
				"Luxury<span class='news-font'> Regedit</span>",
				"Premium<span class='news-font'> Hax</span>",
				"Always<span class='news-font'> Quality</span>",
				"Best<span class='news-font'> Price</span>",
			],
			autoStart: true,
			loop: true,
			delay: 45,
			deleteSpeed: 30,
			pauseFor: 1500,
			cursor: "|",
		});
	}

	// --- LOGICA DE LANYARD (DISCORD) ---
	const DISCORD_ID = "1033641221354164294";

	async function updateDiscordStatus() {
		try {
			const response = await fetch(
				`https://api.lanyard.rest/v1/users/${DISCORD_ID}`,
			);
			const data = await response.json();

			if (data.success) {
				const user = data.data.discord_user;
				const status = data.data.discord_status;
				const activities = data.data.activities;

				// Actualizar nombre y PFP
				const usernameEl = document.getElementById("discord-username");
				const pfpEl = document.getElementById("discord-pfp");
				const pfpPlaceholder = document.getElementById(
					"discord-pfp-placeholder",
				);

				if (usernameEl) usernameEl.textContent = user.username;

				if (pfpEl && user.avatar) {
					pfpEl.src = `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.webp?size=128`;
					pfpEl.style.display = "block";
					if (pfpPlaceholder) pfpPlaceholder.style.display = "none";
				}

				// Actualizar punto de estado
				const statusDot = document.getElementById("discord-status");
				if (statusDot) {
					statusDot.className = `status-dot ${status}`;
				}

				// Actualizar actividad

				const activityNameEl = document.getElementById(
					"discord-activity-name",
				);
				const activityDetailsEl = document.getElementById(
					"discord-activity-details",
				);
				const activityIcon = document.getElementById(
					"discord-activity-icon",
				);
				const defaultIcon = document.getElementById(
					"discord-default-icon",
				);
				const techBox = document.getElementById("discord-tech-box");

				if (activities.length > 0 || data.data.listening_to_spotify) {
					let activity = activities.find((a) => a.type !== 4); // Ignorar Custom Status

					// Si escucha Spotify y no hay juego, o si queremos dar prioridad a Spotify
					if (
						data.data.listening_to_spotify &&
						(!activity || activity.name === "Spotify")
					) {
						const spotify = data.data.spotify;
						if (activityNameEl)
							activityNameEl.textContent = "Spotify";
						if (activityDetailsEl)
							activityDetailsEl.textContent = `${spotify.song} - ${spotify.artist}`;

						if (activityIcon && spotify.album_art_url) {
							activityIcon.src = spotify.album_art_url;
							activityIcon.style.display = "block";
							if (defaultIcon) defaultIcon.style.display = "none";
							if (techBox)
								techBox.setAttribute(
									"data-tooltip",
									spotify.album,
								);
						}
					} else if (activity) {
						if (activityNameEl)
							activityNameEl.textContent = activity.name;
						if (activityDetailsEl)
							activityDetailsEl.textContent =
								activity.details || activity.state || "";

						// Intentar cargar imagen del juego/actividad
						if (
							activityIcon &&
							activity.assets &&
							activity.assets.large_image
						) {
							let url = "";
							if (activity.assets.large_image.startsWith("mp:")) {
								url = activity.assets.large_image.replace(
									"mp:",
									"https://media.discordapp.net/",
								);
							} else {
								url = `https://cdn.discordapp.com/app-assets/${activity.application_id}/${activity.assets.large_image}.png`;
							}
							activityIcon.src = url;
							activityIcon.style.display = "block";
							if (defaultIcon) defaultIcon.style.display = "none";

							// Añadir el nombre de la actividad como tooltip (evitando textos técnicos)
							if (techBox)
								techBox.setAttribute(
									"data-tooltip",
									activity.name,
								);
						} else {
							if (activityIcon)
								activityIcon.style.display = "none";
							if (defaultIcon)
								defaultIcon.style.display = "block";
							if (techBox)
								techBox.removeAttribute("data-tooltip");
						}
					}
				} else {
					if (activityNameEl)
						activityNameEl.textContent =
							status === "offline" ? "Desconectado" : "Online";
					if (activityDetailsEl)
						activityDetailsEl.textContent = "Sin actividad";
					if (activityIcon) activityIcon.style.display = "none";
					if (defaultIcon) defaultIcon.style.display = "block";
					if (techBox) techBox.removeAttribute("data-tooltip");
				}
			}
		} catch (error) {
			console.error("Error fetching Discord status:", error);
		}
	}

	// Ejecutar al cargar y cada 30 segundos
	updateDiscordStatus();
	setInterval(updateDiscordStatus, 30000);

	// --- LOGICA DEL GENERADOR ACETERNITY ---
	const genBtn = document.getElementById("generate-btn");
	const terminalContent = document.getElementById("terminal-content");
	const licenseOutput = document.getElementById("license-output");
	const licenseCode = document.getElementById("license-code");
	const copyBtn = document.getElementById("copy-btn");

	// Función mejorada para animar escritura con soporte para múltiples colores
	async function typeMultiColorLine(container, segments) {
		const line = document.createElement("div");
		line.className = "log-line";
		container.appendChild(line);

		for (const segment of segments) {
			const span = document.createElement("span");
			if (segment.className) span.className = segment.className;
			line.appendChild(span);

			for (let i = 0; i < segment.text.length; i++) {
				span.textContent += segment.text[i];
				await new Promise((r) => setTimeout(r, 10)); // Más rápido para mejor sensación
			}
		}

		const viewport = container.closest(".terminal-viewport");
		if (viewport) viewport.scrollTop = viewport.scrollHeight;
	}

	let hasGenerated = false;

	if (genBtn && terminalContent && licenseOutput) {
		genBtn.addEventListener("click", async () => {
			if (hasGenerated) return;
			hasGenerated = true; // Bloqueo inmediato por estado

			genBtn.disabled = true;
			genBtn.classList.add("is-generated");

			// Cambiar texto a estado dinámico
			const btnText = genBtn.querySelector(".btn-text");
			if (btnText) btnText.textContent = "Generando...";
			genBtn.style.opacity = "0.5";
			licenseOutput.style.display = "none";

			terminalContent.innerHTML += `<div class="log-separator"></div>`;

			const steps = [
				{
					type: "multi",
					segments: [
						{ text: "[INFO] ", className: "p-blue" },
						{
							text: "Conectando con nodo regional (México/LATAM)...",
							className: "p-gray",
						},
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "luxury:~$ ", className: "p-prompt" },
						{
							text: "ssh master-db.luxury-api.io --secure",
							className: "p-white",
						},
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "[AUTH] ", className: "p-blue" },
						{ text: "Session ID for ", className: "p-gray" },
						{ text: "0x77A0F", className: "p-purple" },
						{ text: " established.", className: "p-gray" },
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "[WAIT] ", className: "p-yellow" },
						{
							text: "Validando integridad de base de datos...",
							className: "p-gray",
						},
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "luxury:~$ ", className: "p-prompt" },
						{
							text: "SELECT * FROM core_nodes WHERE region='GLOBAL';",
							className: "p-white",
						},
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "[QUERY] ", className: "p-yellow" },
						{
							text: "Found cluster match on ",
							className: "p-gray",
						},
						{ text: "node-alpha-04", className: "p-blue" },
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "✓ ", className: "p-success" },
						{
							text: "RSA Handshake accepted (2048-bit).",
							className: "p-gray",
						},
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "[DB] ", className: "p-blue" },
						{
							text: "Sincronizando registros de usuario premium...",
							className: "p-gray",
						},
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "[FETCH] ", className: "p-purple" },
						{
							text: "Acquiring premium metadata for ",
							className: "p-gray",
						},
						{ text: "lux_88291", className: "p-white" },
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "[OK] ", className: "p-success" },
						{
							text: "Usuario verificado con éxito.",
							className: "p-gray",
						},
					],
				},
				{
					type: "multi",
					segments: [
						{ text: "✓ ", className: "p-success" },
						{
							text: "DONE: Security token deployed.",
							className: "p-gray",
						},
					],
				},
			];

			for (const step of steps) {
				await typeMultiColorLine(terminalContent, step.segments);
				await new Promise((r) => setTimeout(r, 100));
			}

			const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
			const part = () =>
				Array.from(
					{ length: 4 },
					() => chars[Math.floor(Math.random() * chars.length)],
				).join("");
			const key = `LUXURY-${part()}-${part()}-${part()}`;

			licenseCode.textContent = key;
			
			// Activar animación de transformación coordinada
			const terminalFooter = genBtn.closest(".terminal-footer");
			if (terminalFooter) {
				terminalFooter.classList.add("is-finished");
			}
			licenseOutput.style.display = "flex";

			// Transformación Ultra-Minimalista con estructura para cross-fade
			genBtn.innerHTML = `
				<div class="minimal-status">
					<div class="status-content activated-state">
						<span class="m-check">✓</span> 
						<span class="status-label">ACTIVATED</span>
					</div>
					<div class="status-content timer-state" style="opacity: 0; position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none;">
						<span class="status-label timer-label">RESET EN: --:--:--</span>
					</div>
				</div>
			`;

			// Transición sutil al temporizador después de un breve momento
			setTimeout(() => {
				const activatedState = genBtn.querySelector(".activated-state");
				const timerState = genBtn.querySelector(".timer-state");
				const minimalStatus = genBtn.querySelector(".minimal-status");
				
				if (activatedState && timerState && minimalStatus) {
					let secondsLeft = 24 * 60 * 60;

					// Cross-fade suave
					activatedState.style.opacity = "0";
					timerState.style.opacity = "1";
					timerState.style.position = "relative";
					timerState.style.pointerEvents = "auto";
					activatedState.style.position = "absolute";

					minimalStatus.classList.add("is-timer");

					const updateTimer = () => {
						const h = Math.floor(secondsLeft / 3600);
						const m = Math.floor((secondsLeft % 3600) / 60);
						const s = secondsLeft % 60;
						const timerLabel = timerState.querySelector(".timer-label");
						if (timerLabel) {
							timerLabel.innerHTML = `RESET EN: <span class="status-timer">${h.toString().padStart(2, "0")}:${m.toString().padStart(2, "0")}:${s.toString().padStart(2, "0")}</span>`;
						}
					};

					updateTimer();
					setInterval(() => {
						secondsLeft--;
						if (secondsLeft >= 0) updateTimer();
					}, 1000);
				}
			}, 2500);
			genBtn.classList.add("is-activated");
			genBtn.title = "License Active";
		});

		if (copyBtn) {
			copyBtn.addEventListener("click", () => {
				navigator.clipboard.writeText(licenseCode.textContent);
				const icon = copyBtn.innerHTML;
				copyBtn.innerHTML = "✓";
				copyBtn.setAttribute("data-tooltip", "Copiado");
				setTimeout(() => {
					copyBtn.innerHTML = icon;
					copyBtn.setAttribute("data-tooltip", "Copiar");
				}, 2000);
			});
		}
	}
	// --- LOGICA DEL REPRODUCTOR DE MUSICA (v5 - Master Audio) ---
	const playBtn = document.getElementById("master-play-pause");
	const prevBtn = document.getElementById("master-prev");
	const nextBtn = document.getElementById("master-next");
	const playerStatus = document.getElementById("player-status");
	const playIcon = document.getElementById("m-play");
	const pauseIcon = document.getElementById("m-pause");
	const progressBar = document.getElementById("m-fill");
	const progressSeek = document.getElementById("m-seek");
	const currentTimeEl = document.getElementById("m-current");
	const trackTitle = document.querySelector(".master-title");
	const volControl = document.getElementById("vol-control");
	const volFill = document.getElementById("vol-fill");

	let isPlaying = false;
	let currentSeconds = 1; 
	const totalSeconds = 380; // 6:20

	const songs = ["Swing Lynn ( Slowed to Perfection )", "Luxury Rhythm", "Golden Nights", "Ethereal Flow"];
	let currentSongIndex = 0;

	if (playBtn) {
		const masterCard = document.querySelector(".audio-master-card");
		
		playBtn.addEventListener("click", () => {
			isPlaying = !isPlaying;
			updateUI();
		});

		function updateUI() {
			if (isPlaying) {
				playIcon.style.display = "none";
				pauseIcon.style.display = "block";
				if (playerStatus) playerStatus.textContent = "NOW PLAYING";
				if (masterCard) {
					masterCard.classList.add("playing");
					playBtn.classList.add("main-active");
				}
			} else {
				playIcon.style.display = "block";
				pauseIcon.style.display = "none";
				if (playerStatus) playerStatus.textContent = "STOPPED";
				if (masterCard) {
					masterCard.classList.remove("playing");
					playBtn.classList.remove("main-active");
				}
			}
		}

		// Cambiar Pista
		if (prevBtn) {
			prevBtn.addEventListener("click", () => {
				currentSeconds = 0;
				currentSongIndex = (currentSongIndex - 1 + songs.length) % songs.length;
				if (trackTitle) trackTitle.textContent = songs[currentSongIndex];
				updateProgress();
			});
		}
		if (nextBtn) {
			nextBtn.addEventListener("click", () => {
				currentSeconds = 0;
				currentSongIndex = (currentSongIndex + 1) % songs.length;
				if (trackTitle) trackTitle.textContent = songs[currentSongIndex];
				updateProgress();
			});
		}

		// Barra de Progreso (Seeking)
		if (progressSeek) {
			progressSeek.addEventListener("click", (e) => {
				const rect = progressSeek.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const percent = x / rect.width;
				currentSeconds = Math.floor(percent * totalSeconds);
				updateProgress();
			});
		}

		// Barra de Volumen (Simulada)
		if (volControl) {
			volControl.addEventListener("click", (e) => {
				const rect = volControl.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const vPercent = (x / rect.width) * 100;
				if (volFill) volFill.style.width = `${vPercent}%`;
			});
		}

		function updateProgress() {
			const progressPercent = (currentSeconds / totalSeconds) * 100;
			if (progressBar) progressBar.style.width = `${progressPercent}%`;

			const mins = Math.floor(currentSeconds / 60);
			const secs = currentSeconds % 60;
			if (currentTimeEl) {
				currentTimeEl.textContent = `${mins}:${secs.toString().padStart(2, "0")}`;
			}
		}

		setInterval(() => {
			if (isPlaying && currentSeconds < totalSeconds) {
				currentSeconds++;
				updateProgress();
			}
		}, 1000);
	}
</script>

