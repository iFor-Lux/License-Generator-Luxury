---

<div class="audio-master-container">
	<div class="audio-master-card">
		<!-- Top Section: Info & Controls -->
		<div class="master-top">
			<div class="master-info-group">
				<div class="master-avatar-circle">
					<img src="https://images.guns.lol/31c0364b9e0a58a873bbe97f0378895eefe318fa/ds0qCk.gif" alt="Art" />
				</div>
				<div class="master-text">
					<span id="player-status" class="now-playing">STOPPED</span>
					<div class="master-title-wrapper">
						<span class="master-title">Swing Lynn ( Slowed to Perfection )</span>
					</div>
				</div>
			</div>

			<div class="master-controls-group">
				<div class="visualizer-dots">
					<span>.</span><span>.</span><span>.</span><span>.</span>
				</div>
				<div class="circle-controls">
					<button id="master-prev" class="circle-btn" title="Prev">
						<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
					</button>
					<button id="master-play-pause" class="circle-btn" title="Play/Pause">
						<svg id="m-play" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
						<svg id="m-pause" viewBox="0 0 24 24" fill="currentColor" style="display: none;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
					</button>
					<button id="master-next" class="circle-btn" title="Next">
						<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
					</button>
				</div>
			</div>
		</div>

		<!-- Bottom Section: Progress & Volume -->
		<div class="master-bottom">
			<div class="progress-section">
				<div class="m-progress-container">
					<div id="m-seek" class="m-progress-bar">
						<div id="m-fill" class="m-fill">
							<div class="m-thumb"></div>
						</div>
					</div>
					<div class="m-time-row">
						<span id="m-current" class="time-label">0:01</span>
						<span class="time-label">6:20</span>
					</div>
				</div>
			</div>
			
			<div class="volume-section">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="vol-icon"><path d="M11 5L6 9H2v6h4l5 4V5z"></path></svg>
				<div id="vol-control" class="vol-bar">
					<div id="vol-fill" class="vol-fill"></div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	// --- LOGICA DEL REPRODUCTOR DE MUSICA (v5 - Master Audio) ---
	const playBtn = document.getElementById("master-play-pause");
	const prevBtn = document.getElementById("master-prev");
	const nextBtn = document.getElementById("master-next");
	const playerStatus = document.getElementById("player-status");
	const playIcon = document.getElementById("m-play");
	const pauseIcon = document.getElementById("m-pause");
	const progressBar = document.getElementById("m-fill");
	const progressSeek = document.getElementById("m-seek");
	const currentTimeEl = document.getElementById("m-current");
	const trackTitle = document.querySelector(".master-title");
	const volControl = document.getElementById("vol-control");
	const volFill = document.getElementById("vol-fill");

	let isPlaying = false;
	let currentSeconds = 1; 
	const totalSeconds = 380; // 6:20

	const songs = ["Swing Lynn ( Slowed to Perfection )", "Luxury Rhythm", "Golden Nights", "Ethereal Flow"];
	let currentSongIndex = 0;

	if (playBtn) {
		const masterCard = document.querySelector(".audio-master-card");
		
		playBtn.addEventListener("click", () => {
			isPlaying = !isPlaying;
			updateUI();
		});

		function updateUI() {
			if (playBtn) {
				if (isPlaying) {
					if (playIcon) playIcon.style.display = "none";
					if (pauseIcon) pauseIcon.style.display = "block";
					if (playerStatus) playerStatus.textContent = "NOW PLAYING";
					if (masterCard) {
						masterCard.classList.add("playing");
						playBtn.classList.add("main-active");
					}
				} else {
					if (playIcon) playIcon.style.display = "block";
					if (pauseIcon) pauseIcon.style.display = "none";
					if (playerStatus) playerStatus.textContent = "STOPPED";
					if (masterCard) {
						masterCard.classList.remove("playing");
						playBtn.classList.remove("main-active");
					}
				}
			}
		}

		// Cambiar Pista
		if (prevBtn) {
			prevBtn.addEventListener("click", () => {
				currentSeconds = 0;
				currentSongIndex = (currentSongIndex - 1 + songs.length) % songs.length;
				if (trackTitle) trackTitle.textContent = songs[currentSongIndex];
				updateProgress();
			});
		}
		if (nextBtn) {
			nextBtn.addEventListener("click", () => {
				currentSeconds = 0;
				currentSongIndex = (currentSongIndex + 1) % songs.length;
				if (trackTitle) trackTitle.textContent = songs[currentSongIndex];
				updateProgress();
			});
		}

		function updateProgress() {
			const percent = (currentSeconds / totalSeconds) * 100;
			if (progressBar) progressBar.style.width = `${percent}%`;
			
			const m = Math.floor(currentSeconds / 60);
			const s = currentSeconds % 60;
			if (currentTimeEl) currentTimeEl.textContent = `${m}:${s.toString().padStart(2, "0")}`;
		}

		// Barra de Progreso (Seeking)
		if (progressSeek) {
			progressSeek.addEventListener("click", (e: MouseEvent) => {
				const rect = progressSeek.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const percent = x / rect.width;
				currentSeconds = Math.floor(percent * totalSeconds);
				updateProgress();
			});
		}

		// Barra de Volumen (Simulada)
		if (volControl) {
			volControl.addEventListener("click", (e: MouseEvent) => {
				const rect = volControl.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const vPercent = (x / rect.width) * 100;
				if (volFill) volFill.style.width = `${vPercent}%`;
			});
		}

		// Temporizador de progreso (Simulado)
		setInterval(() => {
			if (isPlaying) {
				currentSeconds++;
				if (currentSeconds > totalSeconds) currentSeconds = 0;
				updateProgress();
			}
		}, 1000);
	}
</script>

<style is:global>
	.audio-master-container {
		width: 100%;
		max-width: 710px;
		margin-top: 2rem;
		animation: slideIn 1.5s cubic-bezier(0.16, 1, 0.3, 1);
