---
import AudioPlayerContainer from './react/AudioPlayerContainer.jsx';
---

<div class="audio-master-container">
	<AudioPlayerContainer client:load />
</div>





<style is:global>
	.audio-master-container {
		width: 100%;
		max-width: 710px;
		margin-top: 2rem;
		animation: slideIn 1.5s cubic-bezier(0.16, 1, 0.3, 1);
		z-index: 10;
		padding-bottom: 3rem;
	}

	.audio-master-card {
		background: rgba(10, 10, 10, 0.45);
		backdrop-filter: blur(50px);
		-webkit-backdrop-filter: blur(50px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 24px;
		padding: 1rem 1.5rem; /* Ajustado ligeramente */
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
	}

	.master-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	.master-info-group {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex: 1;
		min-width: 0;
	}

	.master-avatar-circle {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		overflow: hidden;
		flex-shrink: 0;
		border: 1px solid rgba(255, 255, 255, 0.15);
		background: rgba(255, 255, 255, 0.03);
	}

	.master-avatar-circle img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.8;
	}

	.master-text {
		display: flex;
		flex-direction: column;
		gap: 0px;
		min-width: 0;
	}

	.now-playing {
		font-size: 0.65rem;
		font-weight: 800;
		color: rgba(255, 255, 255, 0.3);
		letter-spacing: 1px;
		text-transform: uppercase;
		font-family: system-ui, sans-serif;
	}

	.audio-master-card.playing .now-playing {
		color: #ffcc33;
		text-shadow: 0 0 10px rgba(255, 204, 51, 0.4);
	}

	.master-title-wrapper {
		white-space: nowrap;
		overflow: hidden;
		position: relative;
	}

	.master-title {
		color: #ffffff;
		font-size: 0.85rem;
		font-weight: 600;
		display: block !important;
		font-family: system-ui, sans-serif;
		white-space: nowrap !important;
		overflow: hidden !important;
		text-overflow: ellipsis !important;
		max-width: 250px;
	}

	.master-controls-group {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-shrink: 0;
	}

	.visualizer-bars {
		display: flex;
		align-items: flex-end;
		gap: 3px;
		height: 18px;
		width: 45px;
		justify-content: center;
		margin-bottom: 6px;
	}

	.bar {
		width: 4px;
		height: 100%;
		background: linear-gradient(to bottom, #ffffff 0%, rgba(255, 255, 255, 0.5) 50%, rgba(255, 255, 255, 0.1) 100%);
		border-radius: 10px;
		transform-origin: bottom;
		transition: transform 0.1s cubic-bezier(0.17, 0.67, 0.83, 0.67);
		will-change: transform;
	}

	.circle-controls {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.circle-btn {
		width: 42px;
		height: 42px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: rgba(255, 255, 255, 0.7);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
	}

	.circle-btn:hover {
		background: rgba(255, 255, 255, 0.1);
		color: #ffffff;
		transform: scale(1.05);
		border-color: rgba(255, 255, 255, 0.2);
	}

	.circle-btn.main-active {
		width: 50px;
		height: 50px;
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.2);
		color: #ffffff;
	}

	.audio-master-card.playing .circle-btn.main-active {
		background: rgba(255, 204, 51, 0.12);
		color: #ffcc33;
		border-color: rgba(255, 204, 51, 0.4);
		box-shadow: 0 0 20px rgba(255, 204, 51, 0.2);
	}

	.circle-btn svg {
		width: 18px;
		height: 18px;
		filter: drop-shadow(0 0 5px rgba(0,0,0,0.5));
	}

	.circle-btn.main-active svg {
		width: 22px;
		height: 22px;
	}

	.circle-btn.secondary-btn {
		width: 34px;
		height: 34px;
		margin-right: 0.5rem;
		opacity: 0.6;
	}

	.circle-btn.secondary-btn svg {
		width: 14px;
		height: 14px;
	}

	.circle-btn.secondary-btn.active-shuffle {
		opacity: 1;
		color: #ffcc33;
		border-color: rgba(255, 204, 51, 0.3);
		background: rgba(255, 204, 51, 0.05);
	}

	.master-bottom {
		display: flex;
		align-items: flex-start;
		gap: 1.5rem;
		padding-top: 0.25rem;
	}

	.progress-section {
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.m-progress-container {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.m-progress-bar {
		width: 100%;
		height: 3px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 2px;
		position: relative;
		cursor: pointer;
	}

	.m-fill {
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 1%;
		background: #ffcc33;
		border-radius: 2px;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		box-shadow: 0 0 8px rgba(255, 204, 51, 0.4);
	}

	.m-thumb {
		width: 6px;
		height: 6px;
		background: #ffffff;
		border-radius: 50%;
		margin-right: -3px;
		box-shadow: 0 0 10px #ffcc33;
	}

	.m-time-row {
		display: flex !important;
		flex-direction: row !important;
		justify-content: space-between !important;
		width: 100%;
		margin-top: 4px;
	}

	.time-label {
		display: inline-block;
		font-size: 0.65rem;
		color: rgba(255, 255, 255, 0.4);
		font-family: inherit;
		min-width: 35px;
	}

	.volume-section {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		width: 110px;
		margin-top: 10px;
	}

	.vol-icon {
		width: 12px;
		height: 12px;
		color: rgba(255, 255, 255, 0.8);
	}

	.vol-bar {
		flex: 1;
		height: 3px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 2px;
	}

	.vol-fill {
		width: 100%;
		height: 100%;
		background: rgba(255, 255, 255, 0.85);
		border-radius: 2px;
	}

	@media (max-width: 650px) {
		.audio-master-container {
			width: 95%;
			margin-top: 1rem;
			padding-bottom: 2rem;
		}
		.audio-master-card {
			width: 100%;
			padding: 1rem 0.75rem; /* Padding reducido en móvil para que el slider ocupe más */
			gap: 0.5rem;
			border-radius: 16px;
		}
		.master-top {
			gap: 0.5rem;
			justify-content: space-between;
		}
		.master-info-group {
			gap: 0.75rem;
			flex: 1;
			min-width: 0;
		}
		.master-avatar-circle {
			width: 40px;
			height: 40px;
		}
		.master-title {
			font-size: 0.8rem;
			max-width: 140px;
		}
		.now-playing {
			font-size: 0.6rem;
		}
		.master-controls-group {
			gap: 0.4rem;
		}
		.visualizer-bars {
			width: 35px;
			margin-bottom: 4px;
		}
		.circle-btn {
			width: 38px;
			height: 38px;
		}
		.circle-btn.main-active {
			width: 46px; 
			height: 46px;
		}
		.circle-btn svg {
			width: 16px;
			height: 16px;
		}
		.circle-btn.main-active svg {
			width: 20px;
			height: 20px;
		}
		.master-bottom {
			flex-direction: column;
			gap: 1.5rem;
			width: 100%;
			padding-top: 0.5rem;
		}
		.progress-section {
			width: 100%;
		}
		.volume-section {
			display: flex;
			width: 100%;
			margin-top: -0.5rem;
		}
		.vol-bar {
			flex: 1;
		}
		.time-label {
			font-size: 0.5rem;
		}
	}
</style>
