---
import "./Card.css";
---

<div class="card group-card">
	<div class="card-left">
		<div class="group-avatar-container" data-tooltip="Join our Community">
			<img src="profile.png" alt="Group" class="group-avatar" />
		</div>
		<div class="info">
			<span class="group-name">Luxury Clientes</span>
			<div class="subs-row">
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					class="users-icon"
					><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
					></path><circle cx="9" cy="7" r="4"></circle><path
						d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path
						d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
				>
				<span class="subs-count">7,321 Clientes</span>
			</div>
			<a href="#" class="join-pill">Comprar</a>
		</div>
	</div>
</div>

<style is:global>
	.group-avatar-container {
		width: 75px;
		height: 75px;
		border-radius: 12px;
		overflow: visible;
		flex-shrink: 0;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.group-avatar {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 12px;
	}

	.join-pill {
		display: inline-block;
		margin-top: 4px;
		padding: 2px 16px;
		background: #3498db;
		color: white;
		border-radius: 20px;
		font-size: 0.7rem;
		font-weight: 600;
		text-decoration: none;
		width: fit-content;
		transition: none;
	}

	.join-pill:hover {
		background: #3498db;
	}

	.group-name {
		font-family: inherit;
		font-weight: 400;
		color: #ffcc33;
		font-size: 0.95rem;
		line-height: 1.1;
	}

	.subs-row {
		display: flex;
		align-items: center;
		gap: 4px;
		color: rgba(255, 255, 255, 0.3);
		margin: 2px 0;
	}

	.users-icon {
		width: 12px;
		height: 12px;
	}

	.subs-count {
		font-family: inherit;
		font-size: 0.75rem;
	}

	@media (max-width: 480px) {
		.group-avatar-container {
			width: 60px;
			height: 60px;
		}
		.group-name {
			font-size: 0.85rem;
		}
	}
</style>
